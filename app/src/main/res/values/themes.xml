<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GMDM" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/gmdm_primary</item>
        <item name="colorPrimaryDark">@color/gmdm_primary_dark</item>
        <item name="colorOnPrimary">@color/gmdm_on_primary</item>
        <item name="android:statusBarColor">@color/gmdm_primary_dark</item>
        <item name="android:navigationBarColor">@color/gmdm_primary_dark</item>
        <item name="android:windowBackground">@color/gmdm_surface</item>
    </style>

    <style name="Theme.GMDM.LockScreen" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@color/lock_screen_background</item>
        <item name="android:navigationBarColor">@color/lock_screen_background</item>
        <item name="android:windowBackground">@color/lock_screen_background</item>
        <item name="android:windowShowWallpaper">false</item>
    </style>

</resources>
